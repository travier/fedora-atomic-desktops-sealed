ARG BASE=overridden
FROM $BASE as rootfs

RUN <<EORUN
set -euxo pipefail
kver=$(cd "/usr/lib/modules" && echo *)
# Move the kernel to the root of the image
mv "/usr/lib/modules/$kver/vmlinuz" "/vmlinuz"
EORUN

FROM scratch
COPY --from=rootfs /vmlinuz /vmlinuz
