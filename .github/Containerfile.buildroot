ARG RELEASE=overridden

FROM ghcr.io/sigstore/cosign/cosign:v2.6.2 as cosign-bin

FROM registry.fedoraproject.org/fedora-minimal:${RELEASE}

COPY --from=cosign-bin /ko-app/cosign /usr/bin/cosign

RUN dnf -y upgrade \
    && \
    dnf -y install --allowerasing \
        buildah \
        git-core \
        just \
        podman \
        skopeo \
    && \
    dnf clean all
